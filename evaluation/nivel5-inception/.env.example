# .env.example — copia esto a .env y rellena con tus valores
# IMPORTANTE: el fichero .env debe estar en .gitignore
# NUNCA subas credenciales reales a git

# ── Tu login de 42 ──────────────────────────────────────────
LOGIN=ismherna

# ── Dominio (login.42.fr para el subject) ──────────────────
DOMAIN_NAME=ismherna.42.fr

# ── MariaDB ─────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=cambia_esto_root
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=cambia_esto_wp

# ── WordPress ───────────────────────────────────────────────
WP_TITLE=Mi sitio WordPress
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=cambia_esto_admin
WP_ADMIN_EMAIL=admin@ismherna.42.fr
WP_USER=otro_usuario
WP_USER_PASSWORD=cambia_esto_user
WP_USER_EMAIL=user@ismherna.42.fr
